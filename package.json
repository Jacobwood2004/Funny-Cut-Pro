{
  "name": "funny-cut-pro",
  "productName": "Funny Cut Pro",
  "version": "1.0.0",
  "description": "Funny Cut Pro — a fast clip-sorting and trimming workflow for reviewing recorded clips.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "Funny Studio",
  "license": "MIT",
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "com.funnycut.pro",
    "productName": "Funny Cut Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!*.bat",
      "!make-icon.js",
      "!README.md",
      "!.claude/**",
      "!dist/**",
      "!build/wordmark*.png",
      "!build/installerSidebar.*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Funny Cut Pro",
      "artifactName": "Funny Cut Pro Setup.${ext}",
      "uninstallDisplayName": "Funny Cut Pro",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp"
    }
  }
}
